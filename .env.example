DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

GITHUB_ACCESS_TOKEN=
GITHUB_USERNAME=
GITHUB_REPOSITORY=

# Optional: if "false", new Discord messages are NOT auto-synced as GitHub
# issue comments. Users can still sync individual messages via the
# "Sync to Issue" message context menu command (right-click a message ->
# Apps -> Sync to Issue). Default: true.
AUTO_SYNC_COMMENTS=true

# Recommended: shared secret configured on the GitHub webhook. Requests with
# a missing/invalid X-Hub-Signature-256 will be rejected with 401. Leave blank
# to disable verification (NOT recommended for public deployments).
GITHUB_WEBHOOK_SECRET=

# Tag <-> issue-state mapping lives in src/tagMapping.config.json, not in env.
